<ConstructionScreen>:
    FloatLayout:

        canvas.before:
            Rectangle:
                source: "assets/construction.png"
                size: self.size
                pos: self.pos

        Label:
            text: "PAGINA EN CONSTRUCCION"
            font_size: 50
            color: 1, 1, 0, 1    # amarillo (R,G,B,A)
            pos_hint: {"center_x": 0.25, "center_y": 0.75}


        Button:
            text: "Atras"
            font_size: 32
            color: 1, 0, 0, 1          # texto amarillo
            background_normal: ""     # quita la textura default
            size_hint: 0.2, 0.10
            pos_hint: {"center_x": 0.5, "center_y": 0.35}
            on_release: 
                app.root.transition = SlideTransition(direction="right", duration=0.3)
                app.root.current = "play"
                app.root.transition = SlideTransition(direction="left", duration=0.3)
            background: ""
            background_color: 0,0,0,0
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.5   # fondo negro semi-transparente
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20, 20, 20, 20]
