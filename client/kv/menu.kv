#:import SlideTransition kivy.uix.screenmanager.SlideTransition
#:import FadeTransition kivy.uix.screenmanager.FadeTransition
#:import Factory kivy.factory.Factory

<MenuScreen>:
    FloatLayout:

        canvas.before:
            Rectangle:
                source: "assets/background_menu.png"
                size: self.size
                pos: self.pos

        # Language button (top-right)
        Button:
            text: root.btn_language
            font_size: 20
            color: 1, 1, 0, 1
            background_normal: ""
            size_hint: 0.2, 0.08
            pos_hint: {"right": 0.95, "top": 0.95}
            on_release: root.change_language()
            background: ""
            background_color: 0,0,0,0
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.5
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [15, 15, 15, 15]

        Button:
            text: root.btn_play
            font_size: 32
            color: 1, 0, 0, 1
            background_normal: ""
            size_hint: 0.3, 0.10
            pos_hint: {"center_x": 0.5, "center_y": 0.55}
            on_release: 
                app.root.transition = FadeTransition(duration=0.1)
                app.root.current = "play"
                app.root.transition = SlideTransition(direction="left", duration=0.3)
            background: ""
            background_color: 0,0,0,0
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.5
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20, 20, 20, 20]  

        Button:
            text: root.btn_tutorial
            font_size: 32
            color: 1, 0, 0, 1
            background_normal: ""
            size_hint: 0.3, 0.10
            pos_hint: {"center_x": 0.5, "center_y": 0.40}
            on_release: app.root.current = "construction"
            background: ""
            background_color: 0,0,0,0
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.5
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20, 20, 20, 20]  

        Button:
            text: root.btn_exit
            font_size: 32
            color: 1, 0, 0, 1
            background_normal: ""
            size_hint: 0.3, 0.10
            pos_hint: {"center_x": 0.5, "center_y": 0.25}
            on_release:
                Factory.ConfirmExitPopup().open()
            background: ""
            background_color: 0,0,0,0
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.5
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20, 20, 20, 20]  


<ConfirmExitPopup@Popup>:
    title: ""
    separator_height: 0
    size_hint: 0.5, 0.4
    auto_dismiss: True
    background: ""
    background_color: 0,0,0,0

    canvas.before:
        Color:
            rgba: 0, 0, 0, 0.7
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [20, 20, 20, 20]
