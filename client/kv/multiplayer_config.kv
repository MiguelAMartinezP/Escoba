<MultiplayerConfigScreen>:
    FloatLayout:

        canvas.before:
            Rectangle:
                source: "assets/background.png"
                size: self.size
                pos: self.pos

        Label:
            text: root.title_text
            font_size: 60
            color: 1, 0, 0, 1
            pos_hint: {"center_x": 0.5, "center_y": 0.85}

        Label:
            text: root.player_label
            font_size: 32
            color: 1, 0, 0, 1
            pos_hint: {"center_x": 0.25, "center_y": 0.60}

        TextInput:
            id: player_input
            text: ""
            multiline: False
            font_size: 28
            size_hint: 0.5, None
            height: 50
            pos_hint: {"center_x": 0.65, "center_y": 0.60}

        Label:
            text: root.room_label
            font_size: 32
            color: 1, 0, 0, 1
            pos_hint: {"center_x": 0.25, "center_y": 0.50}

        TextInput:
            id: lobby_input
            text: ""
            multiline: False
            font_size: 28
            size_hint: 0.5, None
            height: 50
            pos_hint: {"center_x": 0.65, "center_y": 0.50}

        Label:
            text: root.server_status
            font_size: 24
            color: (1, 0, 0, 1) if root.connection_error else (0, 1, 0, 1)  # Red if error, Green if ok
            pos_hint: {"center_x": 0.5, "center_y": 0.42}
            size_hint: 0.8, None
            height: 40
            halign: 'center'
            valign: 'middle'

        Button:
            text: root.create_button
            font_size: 32
            color: 1, 1, 1, 1
            background_normal: ""
            background_color: 0, 0.5, 0.5, 0.8
            size_hint: 0.25, 0.10
            pos_hint: {"center_x": 0.35, "center_y": 0.36}
            on_release: root.create_lobby()
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.5
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20, 20, 20, 20]

        Button:
            text: root.join_button
            font_size: 32
            color: 1, 1, 1, 1
            background_normal: ""
            background_color: 0, 0.3, 0.7, 0.8
            size_hint: 0.25, 0.10
            pos_hint: {"center_x": 0.65, "center_y": 0.36}
            on_release: root.join_lobby()
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.5
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20, 20, 20, 20]

        Button:
            text: root.back_button
            font_size: 32
            color: 1, 0, 0, 1
            background_normal: ""
            size_hint: 0.22, 0.08
            pos_hint: {"center_x": 0.5, "center_y": 0.12}
            on_release:
                app.root.transition = SlideTransition(direction="right", duration=0.3)
                app.root.current = "play"
                app.root.transition = SlideTransition(direction="left", duration=0.3)
            background: ""
            background_color: 0,0,0,0
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.5
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20, 20, 20, 20]
