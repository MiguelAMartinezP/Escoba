#:include kv/menu.kv
#:include kv/game.kv
#:include kv/play.kv
#:include kv/game_config.kv
#:include kv/custom.kv
#:include kv/multiplayer_config.kv
#:include kv/construction.kv
#:include kv/lobby.kv
#:include kv/widgets.kv

#:import SlideTransition kivy.uix.screenmanager.SlideTransition
#:import FadeTransition kivy.uix.screenmanager.FadeTransition

ScreenManager:
    transition: SlideTransition(direction="left", duration=0.3)
    id: screen_manager

    MenuScreen:
        name: "menu"

    PlayScreen:
        name: "play"

    MultiplayerConfigScreen:
        name: "multiplayer_config"

    LobbyScreen:
        name: "lobby"

    GameScreen:
        name: "game"

    ConstructionScreen:
        name: "construction"
