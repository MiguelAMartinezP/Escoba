<GameConfigScreen>:
    FloatLayout:

        canvas.before:
            Rectangle:
                source: "assets/background.png"
                size: self.size
                pos: self.pos

        Label:
            text: root.title_text
            font_size: 48
            color: 1, 1, 1, 1
            pos_hint: {"center_x": 0.5, "center_y": 0.85}
            size_hint: 0.9, 0.15

        Label:
            text: root.difficulty_text
            font_size: 32
            color: 1, 1, 1, 1
            pos_hint: {"center_x": 0.5, "center_y": 0.70}
            size_hint: 0.9, 0.10

        Button:
            text: root.easy_button
            font_size: 28
            color: 0, 1, 0, 1
            background_normal: ""
            size_hint: 0.3, 0.10
            pos_hint: {"center_x": 0.5, "center_y": 0.55}
            on_release: root.start_game("easy")
            background_color: 0, 0, 0, 0
            canvas.before:
                Color:
                    rgba: 0, 0.5, 0, 0.5
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20, 20, 20, 20]

        Button:
            text: root.medium_button
            font_size: 28
            color: 1, 1, 0, 1
            background_normal: ""
            size_hint: 0.3, 0.10
            pos_hint: {"center_x": 0.5, "center_y": 0.42}
            on_release: root.start_game("medium")
            background_color: 0, 0, 0, 0
            canvas.before:
                Color:
                    rgba: 0.5, 0.5, 0, 0.5
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20, 20, 20, 20]

        Button:
            text: root.hard_button
            font_size: 28
            color: 1, 0, 0, 1
            background_normal: ""
            size_hint: 0.3, 0.10
            pos_hint: {"center_x": 0.5, "center_y": 0.29}
            on_release: root.start_game("hard")
            background_color: 0, 0, 0, 0
            canvas.before:
                Color:
                    rgba: 0.5, 0, 0, 0.5
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20, 20, 20, 20]

        Button:
            text: root.back_button
            font_size: 28
            color: 1, 0, 0, 1
            background_normal: ""
            size_hint: 0.3, 0.10
            pos_hint: {"center_x": 0.5, "center_y": 0.13}
            on_release: app.root.current = "play"
            background_color: 0, 0, 0, 0
            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.5
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20, 20, 20, 20]
