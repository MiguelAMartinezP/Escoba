<GameScreen>:
    canvas.before:
        Rectangle:
            source: "assets/background.png"
            size: self.size
            pos: self.pos

    CardGame:
        id: card_game

    Button:
        text: "Atras"
        font_size: 32
        color: 1, 0, 0, 1          # texto amarillo
        background_normal: ""     # quita la textura default
        size_hint: 0.2, 0.10
        pos_hint: {"center_x": 0.8, "center_y": 0.80}
        on_release: 
            app.root.transition = SlideTransition(direction="right", duration=0.3)
            app.root.current = "play"
            app.root.transition = SlideTransition(direction="left", duration=0.3)
        background: ""
        background_color: 0,0,0,0
        canvas.before:
            Color:
                rgba: 0, 0, 0, 0.5   # fondo negro semi-transparente
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [20, 20, 20, 20]
